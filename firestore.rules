rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ ฟังก์ชันตรวจสอบ Role (ใช้ Custom Claims เป็นหลักเพื่อลด Quota Read, ไม่ Fallback ไปหา DB แล้วเพื่อป้องกัน Read Cost มหาศาลจาก User ทั่วไป)
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isStaff() {
      return isAuthenticated() && (
        request.auth.token.role == 'staff' ||
        request.auth.token.role == 'manager' ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'owner' ||
        request.auth.token.isStaff == true ||
        request.auth.uid == '8rP6WhimrqOILBId86bkTsvNHFf1' // TODO: REMOVE LATER - Temporary bypass for development testing
      );
    }

    function isManagerOrAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'manager' ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'owner' ||
        request.auth.uid == '8rP6WhimrqOILBId86bkTsvNHFf1' // Bypass for owner
      );
    }
    
    // ============================================
    // 🌟 กฎของ Collections ต่างๆ
    // ============================================

    // 1. ผู้ใช้ (Users)
    match /users/{userId} {
      // สงวนสิทธิ์การอ่านข้อมูลส่วนบุคคลเฉพาะเจ้าของและพนักงานเท่านั้น (PDPA Compliance)
      allow read: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      // เจ้าของบัญชี หรือ พนักงาน(Staff) แก้ไขได้
      allow write: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      
      // ให้สิทธิ์การเข้าถึง Subcollections (เช่น storeProfile, wallet)
      match /{document=**} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isStaff());
        allow write: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      }
    }
    
    // 1.1 ผู้ใช้ (Users) ในระบบ Artifacts
    match /artifacts/{appId}/users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      
      match /{document=**} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isStaff());
        allow write: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      }
    }

    // 2. สินค้าคงคลัง (Products)
    match /products/{productId} {
      // ลูกค้าทั่วไปอ่านได้
      allow read: if true;
      // เฉพาะพนักงานเท่านั้นที่แก้ไขจำนวนสต๊อก หรือข้อมูลทั้งหมดได้
      allow write: if isStaff();
      // อนุญาตให้ User ทั่วไป (ที่ล็อกอิน) อัปเดตได้เฉพาะคะแนนรีวิวและสต๊อก (เวลาสั่งซื้อ)
      allow update: if isAuthenticated() && 
                    request.resource.data.diff(resource.data).affectedKeys()
                    .hasOnly(['reviewCount', 'averageRating', 'stockQuantity', 'stats']);
    }

    // 2.1 รีวิวสินค้า (Product Reviews)
    match /product_reviews/{reviewId} {
      allow read: if true; // ทุกคนอ่านรีวิวได้
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid; // ต้องล็อกอินถึงจะเขียนรีวิวได้
      allow update: if isAuthenticated(); // สำหรับการกด Like
      allow delete: if isManagerOrAdmin(); // เฉพาะผู้ดูแลลบได้
    }

    // 3. ระบบบิลและการเงิน (Orders & Credit)
    match /orders/{orderId} {
      allow read: if isStaff() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || resource.data.customer.uid == request.auth.uid));
      allow create: if isStaff() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    match /credit_transactions/{txId} {
      // ลูกค้าดูประวัติกระเป๋าเงินตัวเองได้
      allow read: if isStaff() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      // เฉพาะระบบและพนักงานเขียนได้
      allow write: if isStaff();
    }

    // 4. งานอนุมัติของ Manager (Todos & System Logs)
    match /todos/{todoId} {
      allow read: if isStaff() || (isAuthenticated() && (
        resource == null ||
        resource.data.createdByUid == request.auth.uid || 
        resource.data.createdBy == request.auth.uid || 
        resource.data.customerUid == request.auth.uid || 
        resource.data.uid == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      ));
      allow create: if isStaff() || (isAuthenticated() && (
        request.resource.data.createdByUid == request.auth.uid || 
        request.resource.data.createdBy == request.auth.uid ||
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.partnerId == request.auth.uid
      ));
      allow update: if isStaff() || (isAuthenticated() && (
        resource == null ||
        resource.data.createdByUid == request.auth.uid || 
        resource.data.createdBy == request.auth.uid || 
        resource.data.customerUid == request.auth.uid || 
        resource.data.uid == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        request.resource.data.createdBy == request.auth.uid ||
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.partnerId == request.auth.uid
      ));
      allow delete: if isStaff() || (isAuthenticated() && (
        resource == null ||
        resource.data.createdByUid == request.auth.uid || 
        resource.data.createdBy == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      ));
    }
    
    match /system_logs/{logId} {
      allow read: if isManagerOrAdmin();
      allow write: if isManagerOrAdmin();
    }

    // 5. ข้อมูลอื่นๆ ที่เป็น Public (หมวดหมู่, หน้าแรก, โฆษณา)
    match /artifacts/{appId}/public/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated(); // จำเป็นต้องอนุญาตสำหรับ Sandbox (การส่งคำขอโฆษณา, ขอถอนเงิน)
    }
    match /homepage_categories/{catId} {
      allow read: if true;
      allow write: if isManagerOrAdmin();
    }
    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isStaff() || (isAuthenticated() && request.auth.uid == partnerId);
    }
    match /ActivePartners/{partnerId} {
      allow read: if true;
      allow write: if isManagerOrAdmin(); // อนุมัติโดยระบบ
    }
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isStaff();
    }
    match /freebies/{freebieId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    // 6. การตั้งค่าระบบ (Settings) และข้อมูลพื้นฐาน
    match /carts/{cartId} {
      allow read, write: if isAuthenticated() && request.auth.uid == cartId;
    }
    match /shipping_rules/{docId} {
      allow read: if true;
      allow write: if isManagerOrAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isManagerOrAdmin();
    }
    
    match /system_config/{docId} {
      // ป้องกันการเข้าถึง Token/Secret ยกเว้น Manager
      allow read, write: if isManagerOrAdmin();
    }
    
    match /counters/{counterId} {
      allow read, write: if isStaff();
    }
    
    match /system_counters/{counterId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /sales_stats/{statId} {
      allow read, write: if isStaff();
    }
    
    match /system_accounts/{accountId} {
      allow read: if true;
      allow write: if isStaff();
    }
  }
}
