rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ ฟังก์ชันตรวจสอบ Role (ใช้ Custom Claims เป็นหลักเพื่อลด Quota Read, ไม่ Fallback ไปหา DB แล้วเพื่อป้องกัน Read Cost มหาศาลจาก User ทั่วไป)
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isStaff() {
      return isAuthenticated() && (
        (request.auth.token.role != null && request.auth.token.role in ['staff', 'manager', 'admin']) ||
        (request.auth.token.isStaff != null && request.auth.token.isStaff == true)
      );
    }

    function isManagerOrAdmin() {
      return isAuthenticated() && (
        (request.auth.token.role != null && request.auth.token.role in ['manager', 'admin'])
      );
    }
    
    // ============================================
    // 🌟 กฎของ Collections ต่างๆ
    // ============================================

    // 1. ผู้ใช้ (Users)
    match /users/{userId} {
      // สงวนสิทธิ์การอ่านข้อมูลส่วนบุคคลเฉพาะเจ้าของและพนักงานเท่านั้น (PDPA Compliance)
      allow read: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      // เจ้าของบัญชี หรือ Manager แก้ไขได้
      allow write: if isAuthenticated() && (request.auth.uid == userId || isManagerOrAdmin());
    }

    // 2. สินค้าคงคลัง (Products)
    match /products/{productId} {
      // ลูกค้าทั่วไปอ่านได้
      allow read: if true;
      // เฉพาะพนักงานเท่านั้นที่แก้ไขจำนวนสต๊อก หรือข้อมูลได้
      allow write: if isStaff();
    }

    // 3. ระบบบิลและการเงิน (Orders & Credit)
    match /orders/{orderId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.customer.uid == request.auth.uid);
      allow write: if isStaff();
    }

    match /credit_transactions/{txId} {
      // ลูกค้าดูประวัติกระเป๋าเงินตัวเองได้
      allow read: if isStaff() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      // เฉพาะระบบและพนักงานเขียนได้
      allow write: if isStaff();
    }

    // 4. งานอนุมัติของ Manager (Todos & System Logs)
    match /todos/{todoId} {
      allow read: if isStaff() || (isAuthenticated() && (resource.data.createdByUid == request.auth.uid || resource.data.customerUid == request.auth.uid || resource.data.uid == request.auth.uid));
      // ลูกค้าทั่วไปสร้าง Todo ได้เฉพาะเคสที่กำหนด และต้องเป็น UID ของตัวเองเท่านั้นเพื่อกัน Spam
      allow create: if isStaff() || (isAuthenticated() && request.resource.data.createdByUid == request.auth.uid);
      allow update: if isStaff() || (isAuthenticated() && (resource.data.createdByUid == request.auth.uid || resource.data.customerUid == request.auth.uid || resource.data.uid == request.auth.uid));
      allow delete: if isStaff();
    }
    
    match /system_logs/{logId} {
      allow read: if isManagerOrAdmin();
      allow write: if isManagerOrAdmin();
    }

    // 5. ข้อมูลอื่นๆ ที่เป็น Public (หมวดหมู่, หน้าแรก, โฆษณา)
    match /homepage_categories/{catId} {
      allow read: if true;
      allow write: if isManagerOrAdmin();
    }
    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isStaff() || (isAuthenticated() && request.auth.uid == partnerId);
    }
    match /ActivePartners/{partnerId} {
      allow read: if true;
      allow write: if isManagerOrAdmin(); // อนุมัติโดยระบบ
    }
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isManagerOrAdmin();
    }
    match /freebies/{freebieId} {
      allow read: if true;
      allow write: if isManagerOrAdmin();
    }
    
    // 6. การตั้งค่าระบบ (Settings)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isManagerOrAdmin();
    }
    
    match /system_config/{docId} {
      // ป้องกันการเข้าถึง Token/Secret ยกเว้น Manager
      allow read, write: if isManagerOrAdmin();
    }
    
    match /counters/{counterId} {
      allow read, write: if isStaff();
    }
  }
}
