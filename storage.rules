rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isStaff() {
      return isAuthenticated() && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['staff', 'manager', 'admin']
        || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isStaff == true
      );
    }

    // 1. ภาพสลิปโอนเงิน (Slips)
    match /slips/{fileName} {
      // พนักงานดูสลิปได้ทุกคน
      allow read: if isAuthenticated();
      // ลูกค้าหรือพนักงานอัปโหลดได้ แต่ห้ามอัปเดตทับไฟล์เดิม (ป้องกันการปลอมแปลง)
      allow write: if isAuthenticated() && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 2. รูปภาพสินค้าและหน้าเว็บ (Public Assets)
    match /products/{fileName} {
      allow read: if true;
      allow write: if isStaff(); // ให้พนักงานหรือผู้จัดการเท่านั้นที่อัปโหลดได้
    }
    
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    // 3. รูปภาพโปรไฟล์พนักงานและคู่ค้า
    match /profiles/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // 4. ค่าเริ่มต้นบล็อกไฟล์ที่ไม่ได้ระบุไว้
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
